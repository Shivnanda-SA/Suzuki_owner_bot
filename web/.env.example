# Optional: call the API directly from the browser (requires CORS on the API for your web origin).
# Leave unset to use same-origin /api-backend (Next.js rewrites to the API — no CORS in dev).
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: where the Next.js server proxies /api-backend (default http://127.0.0.1:8000). Docker web image build uses http://api:8000.
# API_PROXY_TARGET=http://127.0.0.1:8000
