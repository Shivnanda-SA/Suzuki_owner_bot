# Copy to .env in project root for docker compose (OPENAI only; DB is set in compose file)
OPENAI_API_KEY=sk-...

# Optional: protect POST /admin/reindex
# ADMIN_TOKEN=change-me

# Postgres (psycopg3): sessions + feedback only. Vectors live in Chroma (see CHROMA_PERSIST_DIR).
# DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/suzuki
# CHROMA_PERSIST_DIR defaults to ./data/chroma (project root)
